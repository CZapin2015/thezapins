{
  "name": "thezapins",
  "version": "1.0.0",
  "private": true,
  "description": "Wedding website for Stephanie & Corey",
  "scripts": {
    "build": "node build.js",
    "dev": "npx wrangler pages dev dist --d1 DB=thezapins-db",
    "deploy": "npm run build && npx wrangler pages deploy dist",
    "db:init": "npx wrangler d1 execute thezapins-db --file=schema.sql",
    "db:init:remote": "npx wrangler d1 execute thezapins-db --remote --file=schema.sql"
  }
}
